# Google Cloud
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Vertex AI / Gemini
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-1.5-flash-001

# BigQuery
BQ_DATASET=whaletrip
BQ_LOCATION=US

# Firestore (session storage)
FIRESTORE_COLLECTION=whaletrip_sessions

# Maps — set to "google" to use Google Maps, "maplibre" for free OSM tiles
MAPS_PROVIDER=maplibre
GOOGLE_MAPS_API_KEY=

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AGENTS_URL=http://localhost:8001
NEXT_PUBLIC_MAPS_PROVIDER=maplibre
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# API Security
API_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://whtrp.datadinosaur.com

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Travel provider adapters (leave blank to use mock implementations)
GOOGLE_FLIGHTS_API_KEY=
EXPEDIA_API_KEY=
BOOKING_COM_API_KEY=
VIATOR_API_KEY=
GETYOURGUIDE_API_KEY=
